<?xml version="1.0"?>
<robot name="crawl_pole">
    <!-- No "world" link and no fixed/prismatic joint to it: this URDF is loaded
         with useFixedBase=False, so "cart" (the base link) becomes a free
         6-DOF rigid body that rests on the ground plane via gravity + contact,
         exactly like a loose box you dropped on the floor. -->

    <link name="cart">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.00067" iyy="0.00267" izz="0.00267" ixy="0" ixz="0" iyz="0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.2 0.04"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.2 0.04"/></geometry>
        </collision>
    </link>

    <link name="link1">
        <inertial>
            <origin xyz="0 0 0.5" rpy="0 0 0"/>
            <mass value="0.5"/>
            <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0.5" rpy="0 0 0"/>
            <geometry><cylinder radius="0.05" length="1.0"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.5" rpy="0 0 0"/>
            <geometry><cylinder radius="0.05" length="1.0"/></geometry>
        </collision>
    </link>

    <link name="link2">
        <inertial>
            <origin xyz="0 0 0.35" rpy="0 0 0"/>
            <mass value="0.3"/>
            <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0.35" rpy="0 0 0"/>
            <geometry><cylinder radius="0.04" length="0.7"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.35" rpy="0 0 0"/>
            <geometry><cylinder radius="0.04" length="0.7"/></geometry>
        </collision>
    </link>

    <!-- hip origin is pitched 90 degrees about Y so that, at hip_angle=0, link1's
         length axis (local Z) points along world +X instead of world +Z. That's
         what makes the assembly start lying flat along the ground instead of
         standing upright like the balance task. The joint axis is still "0 1 0":
         a rotation about Y is unaffected by an origin rotation that is itself
         about Y, so "hip_angle" still sweeps link1 through the vertical XZ
         plane -- exactly the pitching motion needed to push against the floor. -->
    <joint name="hip" type="revolute">
        <parent link="cart"/>
        <child link="link1"/>
        <origin xyz="0 0 0" rpy="0 1.5708 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="20" lower="-4" upper="4" velocity="10"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <joint name="elbow" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="0 0 1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="15" lower="-4" upper="4" velocity="10"/>
        <dynamics damping="0.1" friction="0.01"/>
    </joint>
</robot>
