<?xml version="1.0"?>
<robot name="single_pendulum_cart">
    <link name="world"/>

    <link name="cart">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.2 0.1"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.2 0.1"/></geometry>
        </collision>
    </link>

    <link name="link1">
        <inertial>
            <origin xyz="0 0 0.5" rpy="0 0 0"/>
            <mass value="0.5"/>
            <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0.5" rpy="0 0 0"/>
            <geometry><cylinder radius="0.03" length="1.0"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.5" rpy="0 0 0"/>
            <geometry><cylinder radius="0.03" length="1.0"/></geometry>
        </collision>
    </link>

    <joint name="rail_to_cart" type="prismatic">
        <parent link="world"/>
        <child link="cart"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit effort="100" lower="-2.5" upper="2.5" velocity="10"/>
    </joint>

    <joint name="hip" type="revolute">
        <parent link="cart"/>
        <child link="link1"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="0" lower="-4" upper="4" velocity="10"/>
        <dynamics damping="0.3" friction="0.05"/>
    </joint>
</robot>
